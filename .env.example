# ========== AI Configuration ==========
AI_API_BASE_URL=https://api.yunjunet.cn/v1
AI_API_KEY=your_yunjunet_api_key_here
AI_MODEL=claude-3-opus-20240229
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7
AI_SYSTEM_PROMPT=你是一个专业的客服助手，请用友好、专业的语气回答用户问题。

# ========== External API Authentication ==========
# 用于外部系统调用企业微信API的密钥（可与AI_API_KEY相同）
API_KEY=your_external_api_key_here

# ========== WeChat Work Configuration ==========
WECOM_CORP_ID=your_corp_id
WECOM_CORP_SECRET=your_corp_secret
WECOM_TOKEN=your_callback_token
WECOM_ENCODING_AES_KEY=your_encoding_aes_key
WECOM_AGENT_ID=your_agent_id
WECOM_API_HOST=https://qyapi.weixin.qq.com/cgi-bin

# ========== Database Configuration ==========
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=wecom_user
DATABASE_PASSWORD=wecom_password
DATABASE_NAME=wecom_ai

# ========== Redis Configuration ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== Server Configuration ==========
NODE_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ========== CORS Configuration ==========
CORS_ORIGIN=*

# ========== Logging ==========
LOG_LEVEL=info
